{
    "scene_type": "distance_barrier_rb_problem",
    "solver": "ipc_solver",
    "timestep": 0.01,
    "max_time": 2.0,
    "distance_barrier_constraint": {        
        "initial_barrier_activation_distance": 5e-4,
        "minimum_separation_distance": 1e-6
    },
    "ipc_solver": {
        "velocity_conv_tol": 1e-3
    },
    "friction_constraints": {
        "iterations": -1
    },
    "rigid_body_problem": {
        "coefficient_restitution": -1,
        "coefficient_friction": 0.3,
        "gravity": [0, 0, 9.8],
        "orthogonality_stiffness": 1e9,
        "rigid_bodies": [{
            "mesh": "cube_drop\\hole.obj",
            "position": [0, 0, 0],
            "rotation": [0, 0, 0],
            "density": 4000
        },
        {
            "mesh": "cube_drop\\cube.obj",
            "position": [0.12, 0, 0],
            "rotation": [0, 0, 0],
            "density": 4000
        }],
        "linear_constraints": [
            {
                "type": "pin_world",
                "body_name": "hole",
                "body_point": [0.0, 0.0, 1.0]
            },
            {
                "type": "pin_world",
                "body_name": "hole",
                "body_point": [1.0, 0.0, 0.0]
            },
            {
                "type": "pin_world",
                "body_name": "hole",
                "body_point": [0.0, 1.0, 0.0]
            }
        ]
    }
}